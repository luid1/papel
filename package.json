{
  "name": "lumin-saas",
  "version": "2.0.0",
  "description": "Lumin Finance — Arquitetura Multi-tenant SaaS (WhatsApp Bot + Firebase + Node.js)",
  "main": "server.js",
  "scripts": {
    "start":     "node server.js",
    "dev":       "nodemon server.js",
    "bot:only":  "node -e \"require('./bot/manager').prototype && new (require('./bot/manager'))().startAll()\"",
    "seed":      "node scripts/seed-company.js"
  },
  "dependencies": {
    "@hapi/boom":            "^10.0.1",
    "@whiskeysockets/baileys":"^6.7.9",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.4.5",
    "express":               "^4.19.2",
    "firebase-admin":        "^12.1.1",
    "openai":                "^4.52.7",
    "pino":                  "^9.2.0",
    "qrcode-terminal":       "^0.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
